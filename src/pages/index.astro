---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroVideo from '../components/HeroVideo.astro';
import StoryGallery from '../components/StoryGallery.astro';
import PlacesMap from '../components/PlacesMap.astro';
import { Image } from 'astro:assets';
import { heroHook } from '../data/hero';
import { reels } from '../data/stories';
import { places } from '../data/places';
import { intro, qna } from '../data/magazine';

// src/assets/about/ 에 사진 넣으면 '탄자니아 알아가기'의 붙박이 이미지로 사용 (없으면 그라데이션)
const aboutMods = import.meta.glob<{ default: ImageMetadata }>('../assets/about/*.{jpg,jpeg,png,webp,JPG,JPEG,PNG,WEBP}', { eager: true });
const aboutKeys = Object.keys(aboutMods).sort();
const aboutImage = aboutKeys.length ? aboutMods[aboutKeys[0]].default : null;
---
<BaseLayout>
  <span id="top"></span>

  <!-- ① 히어로 (풀스크린 영상) -->
  <HeroVideo title={heroHook.title} line={heroHook.line} />

  <!-- ② 탄자니아 알아가기 (풀스크린 붙박이 사진 위로 글자 스크롤) -->
  <section id="why" class="about">
    <div class="about__pin">
      {aboutImage
        ? <Image class="about__bg" src={aboutImage} alt="탄자니아 대자연" widths={[768, 1280, 1920]} sizes="100vw" />
        : <div class="about__bg about__bg--ph"></div>}
      <div class="about__veil"></div>
    </div>
    <div class="about__flow">
      <div class="qblock reveal">
        <p class="tag" style="color:var(--savanna)">{intro.kicker}</p>
        <h2 class="about__headline">{intro.headline}</h2>
        <p class="about__sub">{intro.sub}</p>
      </div>
      {qna.map((item) => (
        <div class="qblock reveal">
          <h3 class="qq">{item.q}</h3>
          <p class="qa">{item.a}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ④ 인터랙티브 지도 -->
  <section id="do" class="section">
    <div class="container">
      <p class="tag">WHAT'S THERE</p>
      <PlacesMap places={places} />
    </div>
  </section>

  <!-- ⑤ 스토리 (지도 아래, 지역별 하이라이트) -->
  <section id="stories" class="stories">
    <div class="container"><p class="tag">OUR STORIES</p></div>
    <div class="bleed-rail">
      <StoryGallery reels={reels} />
    </div>
  </section>

  <!-- ⑥ 공유 CTA → 커뮤니티 플랫폼(예정) -->
  <section class="section section--bush cta-final">
    <div class="container--narrow" style="text-align:center">
      <h2 class="cta-title">당신의 여행도,<br />누군가의 첫 발이 됩니다</h2>
      <p class="cta-lead">사진·영상부터 일정·예산·준비물·꿀팁까지.<br />여행을 통째로 나누는 공간을 만들고 있어요.</p>
      <a class="cta-btn" href="#">이야기 공유하러 가기 →</a>
      <p class="cta-soon">커뮤니티 플랫폼 준비 중 · Coming soon</p>
    </div>
  </section>

  <style>
    .tag { font-family: var(--font-body); font-weight: 800; font-size: 0.78rem; letter-spacing: 0.16em; color: var(--savanna-d); margin: 0 0 1.2rem; }
    .container--narrow { width: min(100% - 2.5rem, var(--maxw-narrow)); margin-inline: auto; }

    /* 스토리 레일 */
    .stories { padding-block: clamp(2.5rem, 6vw, 4.5rem); background: var(--sand-50); }
    .stories .tag { margin-bottom: 0.8rem; }
    .bleed-rail { padding-inline: max(1.25rem, calc((100vw - var(--maxw)) / 2)); }

    /* 탄자니아 알아가기 (풀스크린 붙박이 사진 + 글자 오버레이) */
    .about { position: relative; background: #000; }
    .about__pin { position: sticky; top: 0; height: 100svh; overflow: hidden; }
    .about__bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
    .about__bg--ph { background: linear-gradient(150deg, var(--savanna), var(--terracotta) 55%, var(--ocean)); }
    .about__veil { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(0,0,0,0.18), rgba(0,0,0,0.28) 50%, rgba(0,0,0,0.42)); }
    .about__flow { position: relative; z-index: 2; margin-top: -100svh; color: #fff; }
    .qblock { min-height: 92svh; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; padding: 0 1.25rem; max-width: 760px; margin-inline: auto; }
    .about__headline { font-size: clamp(2.2rem, 7vw, 4.4rem); line-height: 1.15; margin: 0.4rem 0 0; white-space: pre-line; font-weight: 900; letter-spacing: -0.02em; text-shadow: 0 1px 3px rgba(0,0,0,0.7), 0 2px 30px rgba(0,0,0,0.5); }
    .about__sub { margin: 1.4rem auto 0; max-width: 36ch; font-size: clamp(1rem, 2.2vw, 1.2rem); line-height: 1.7; opacity: 0.95; text-shadow: 0 1px 3px rgba(0,0,0,0.75), 0 1px 16px rgba(0,0,0,0.5); white-space: pre-line; }
    .qq { font-size: clamp(1.7rem, 5vw, 2.7rem); margin: 0 0 0.9rem; font-weight: 900; letter-spacing: -0.01em; text-shadow: 0 1px 3px rgba(0,0,0,0.75), 0 2px 26px rgba(0,0,0,0.5); }
    .qa { font-size: clamp(1.05rem, 2.4vw, 1.3rem); line-height: 1.75; margin: 0; max-width: 34ch; opacity: 0.96; text-shadow: 0 1px 2px rgba(0,0,0,0.8), 0 1px 18px rgba(0,0,0,0.55); white-space: pre-line; }

    /* 스크롤 리빌 */
    .reveal { opacity: 0; transform: translateY(28px); transition: opacity 0.7s ease, transform 0.7s ease; }
    .reveal.in { opacity: 1; transform: none; }
    @media (prefers-reduced-motion: reduce) { .reveal { opacity: 1; transform: none; transition: none; } }

    /* 뭘 하나 */
    .do-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: var(--gap); }
    .do-card { border-radius: var(--radius); overflow: hidden; min-height: 220px; display: flex; align-items: flex-end; position: relative; box-shadow: var(--shadow); color: #fff; }
    .do-card--savanna { background: linear-gradient(160deg, var(--savanna), var(--terracotta)); }
    .do-card--ocean { background: linear-gradient(160deg, var(--ocean), var(--ocean-d)); }
    .do-card__img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
    .do-card__body { position: relative; padding: 1.3rem; background: linear-gradient(180deg, transparent, rgba(0,0,0,0.35)); width: 100%; }
    .do-card__emoji { font-size: 1.8rem; }
    .do-card__body h3 { margin: 0.3rem 0 0.3rem; font-size: 1.3rem; }
    .do-card__body p { margin: 0; font-size: 0.95rem; opacity: 0.95; word-break: keep-all; }

    /* 일정 흐름 */
    .phases { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: var(--gap); }
    .phase { background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); padding: 1.6rem; border-top: 5px solid var(--savanna); }
    .phase--ocean { border-top-color: var(--ocean); }
    .phase__tag { font-weight: 800; font-size: 0.75rem; letter-spacing: 0.14em; color: var(--muted); }
    .phase__title { margin: 0.3rem 0 0.6rem; font-size: 1.4rem; }
    .phase__title span { font-size: 0.95rem; color: var(--muted); font-weight: 600; }
    .phase__desc { margin: 0; color: var(--muted); }
    .plan__note { margin-top: 1.5rem; color: var(--muted); font-size: 0.9rem; }

    /* CTA */
    .cta-final { text-align: center; }
    .cta-title { font-size: clamp(1.7rem, 4vw, 2.4rem); }
    .cta-lead { color: #d8cdbb; max-width: 46ch; margin: 0.5rem auto 1.5rem; }
    .cta-title { line-height: 1.25; }
    .cta-btn { display: inline-block; padding: 0.85rem 1.8rem; background: var(--savanna); color: #fff; border-radius: 999px; font-weight: 800; transition: transform 0.15s; }
    .cta-btn:hover { text-decoration: none; transform: translateY(-2px); }
    .cta-soon { margin-top: 1rem; font-size: 0.82rem; color: #b8ad9d; }
  </style>

  <script>
    // 스크롤 시 .reveal 요소가 화면에 들어오면 하나씩 나타남
    const els = document.querySelectorAll('.reveal');
    if ('IntersectionObserver' in window && els.length) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
      }, { threshold: 0.18 });
      els.forEach((el) => io.observe(el));
    } else {
      els.forEach((el) => el.classList.add('in'));
    }
  </script>
</BaseLayout>
