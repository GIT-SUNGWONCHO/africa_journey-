---
const links = [
  { href: '#stories', label: '스토리' },
  { href: '#why', label: '왜 탄자니아' },
  { href: '#do', label: '뭘 하나' },
  { href: '#plan', label: '일정' },
];
---
<header class="nav">
  <div class="container nav__inner">
    <a href="#top" class="nav__brand">TANZANIA<span>· 세렝게티 &amp; 잔지바르</span></a>
    <nav class="nav__links" aria-label="섹션 이동">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--sand-50) 88%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--line);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    height: 60px;
  }
  .nav__brand {
    font-family: var(--font-display);
    font-weight: 900;
    letter-spacing: 0.04em;
    color: var(--ink);
    font-size: 1.05rem;
    white-space: nowrap;
  }
  .nav__brand span { color: var(--muted); font-weight: 500; font-size: 0.78rem; margin-left: 0.4rem; }
  .nav__links { display: flex; gap: clamp(0.6rem, 1.6vw, 1.4rem); overflow-x: auto; }
  .nav__links a {
    color: var(--ink);
    font-size: 0.92rem;
    font-weight: 600;
    white-space: nowrap;
    padding: 0.3rem 0;
    border-bottom: 2px solid transparent;
  }
  .nav__links a:hover { color: var(--savanna-d); border-color: var(--savanna); text-decoration: none; }

  @media (max-width: 640px) {
    .nav__brand span { display: none; }
  }
</style>
