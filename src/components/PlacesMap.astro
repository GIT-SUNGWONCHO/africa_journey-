  'M9147 5664 c-2 -5 -8 -25 -12 -44 -4 -19 -17 -46 -30 -60 -12 -14 -26 -36 -30 -49 l-8 -25 -17 22 c-10 11 -20 18 -24 15 -3 -4 -6 -46 -6 -94 0 -119 27 -207 72 -232 21 -12 34 -15 36 -8 2 6 21 -2 42 -19 28 -22 45 -29 62 -25 20 5 25 -1 45 -52 19 -47 29 -61 54 -70 35 -13 74 -1 66 20 -2 7 -15 52 -27 100 l-23 88 -44 12 c-41 11 -43 13 -43 48 0 39 -21 98 -50 139 -22 32 -30 98 -19 152 9 37 8 44 -14 66 -14 13 -27 20 -30 16z',
