---
import type { Place } from '../data/places';
import { Image } from 'astro:assets';
interface Props { places: Place[]; }
const { places } = Astro.props;

// src/assets/map/ 에 일러스트 지도 이미지를 넣으면 그걸 배경으로 사용 (없으면 SVG 지도).
const mapMods = import.meta.glob<{ default: ImageMetadata }>('../assets/map/*.{png,jpg,jpeg,webp,PNG,JPG,JPEG,WEBP}', { eager: true });
const mapKeys = Object.keys(mapMods).sort();
const mapImage = mapKeys.length ? mapMods[mapKeys[0]].default : null;

