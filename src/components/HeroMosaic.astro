---
import type { Tile } from '../data/hero';
interface Props {
  tiles: Tile[];
  title: string;
  line: string;
}
const { tiles, title, line } = Astro.props;
---
<section class="hero-mosaic">
  <div class="m-grid">
    {tiles.map((t) => (
      <figure class={`m-tile m-tile--${t.span}`}>
        {t.src && t.type === 'video' && (
          <video src={t.src} autoplay muted loop playsinline preload="metadata"></video>
        )}
        {t.src && t.type === 'image' && <img src={t.src} alt={t.alt} loading="eager" />}
        {!t.src && (
          <div class={`m-ph m-ph--${t.tone ?? 'savanna'}`}>
            <span>{t.type === 'video' ? '🎬' : '📷'}</span>
            <small>{t.alt}</small>
          </div>
        )}
      </figure>
    ))}
  </div>
  <div class="hero-overlay">
    <h1>{title}</h1>
    <p>{line}</p>
  </div>
  <a class="hero-scroll" href="#stories" aria-label="아래로">↓</a>
</section>

<style>
  .hero-mosaic { position: relative; }
  .m-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: minmax(0, 1fr);
    grid-auto-flow: dense;
    gap: 4px;
    height: 92svh;
    background: var(--ink);
  }
  .m-tile { margin: 0; overflow: hidden; position: relative; background: var(--bush); }
  .m-tile img, .m-tile video { width: 100%; height: 100%; object-fit: cover; display: block; }
  .m-tile--big { grid-column: span 2; grid-row: span 2; }
  .m-tile--wide { grid-column: span 2; }
  .m-tile--tall { grid-row: span 2; }

  .m-ph {
    width: 100%; height: 100%; display: flex; flex-direction: column;
    align-items: center; justify-content: center; gap: 0.3rem; text-align: center; padding: 0.6rem;
    color: rgba(255,255,255,0.92);
  }
  .m-ph span { font-size: clamp(1.4rem, 3vw, 2.2rem); }
  .m-ph small { font-size: 0.72rem; opacity: 0.85; line-height: 1.3; word-break: keep-all; }
  .m-ph--savanna { background: linear-gradient(150deg, var(--savanna), var(--terracotta)); }
  .m-ph--ocean { background: linear-gradient(150deg, var(--ocean), var(--ocean-d)); }

  .hero-overlay {
    position: absolute; inset: auto 0 0 0; padding: 2.5rem 1.5rem 1.8rem;
    background: linear-gradient(180deg, transparent, rgba(20,17,14,0.8));
    color: #fff; pointer-events: none;
  }
  .hero-overlay h1 {
    font-family: var(--font-body); font-weight: 900; letter-spacing: 0.02em;
    font-size: clamp(2.4rem, 8vw, 5rem); line-height: 0.95; margin: 0; text-shadow: 0 2px 24px rgba(0,0,0,0.4);
  }
  .hero-overlay p { font-size: clamp(1rem, 2.2vw, 1.35rem); font-weight: 600; margin: 0.4rem 0 0; opacity: 0.95; }

  .hero-scroll {
    position: absolute; bottom: 0.6rem; left: 50%; transform: translateX(-50%);
    color: #fff; font-size: 1.4rem; opacity: 0.85; z-index: 2; animation: bob 1.8s ease-in-out infinite;
  }
  .hero-scroll:hover { text-decoration: none; }
  @keyframes bob { 0%,100% { transform: translate(-50%, 0); } 50% { transform: translate(-50%, 7px); } }

  /* 모바일: 2열, 높이 자동(조금 더 길게) */
  @media (max-width: 680px) {
    .m-grid { grid-template-columns: repeat(2, 1fr); height: auto; grid-auto-rows: 30svh; }
    .m-tile--big { grid-column: span 2; grid-row: span 2; }
    .m-tile--wide { grid-column: span 2; grid-row: span 1; }
    .m-tile--tall { grid-column: span 1; grid-row: span 2; }
  }
</style>
