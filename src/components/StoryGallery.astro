---
import type { Reel } from '../data/stories';

interface Props {
  reels: Reel[];
}
const { reels } = Astro.props;
---
<div class="reel-rail" role="list">
  {reels.map((r, i) => (
    <button class={`reel-card reel-card--${r.tone ?? 'savanna'}`} role="listitem" data-reel={i} aria-label={`${r.title} 스토리 보기`}>
      {r.cover && <img class="reel-card__cover" src={r.cover} alt="" loading="lazy" />}
      <div class="reel-card__shade"></div>
      <div class="reel-card__body">
        <span class="reel-card__count">💬 {r.segments.length}</span>
        <h3 class="reel-card__title">{r.title}</h3>
        <span class="reel-card__play">▶ 탭해서 보기</span>
      </div>
    </button>
  ))}
</div>

<script type="application/json" id="reel-data" set:html={JSON.stringify(reels)}></script>

<!-- 풀스크린 스토리 뷰어 -->
<div class="viewer" id="story-viewer" hidden aria-hidden="true">
  <button class="viewer__close" id="vclose" aria-label="닫기">✕</button>
  <div class="viewer__stage" id="vstage">
    <div class="viewer__media" id="vmedia"></div>
    <div class="viewer__bars" id="vbars"></div>
    <div class="viewer__cap" id="vcap"></div>
    <div class="viewer__zone viewer__zone--l" id="vzl" aria-hidden="true"></div>
    <div class="viewer__zone viewer__zone--r" id="vzr" aria-hidden="true"></div>
    <button class="viewer__nav viewer__nav--prev" id="vprev" aria-label="이전">‹</button>
    <button class="viewer__nav viewer__nav--next" id="vnext" aria-label="다음">›</button>
    <div class="viewer__time" id="vtime" hidden></div>
  </div>
</div>

<style is:global>
  /* (is:global) — 뷰어의 영상/이미지/바/캡션은 JS로 동적 삽입되므로 스코프 CSS가 안 먹음.
     클래스명이 이 컴포넌트 전용이라 global 로 둬도 충돌 없음. */
  /* 하이라이트 레일 */
  .reel-rail { display: flex; gap: 0.9rem; overflow-x: auto; padding: 0.5rem 0 1rem; scroll-snap-type: x mandatory; }
  .reel-card {
    flex: 0 0 auto; width: clamp(180px, 46vw, 220px); aspect-ratio: 9/16;
    border: none; padding: 0; border-radius: 18px; overflow: hidden; position: relative;
    cursor: pointer; scroll-snap-align: start; box-shadow: var(--shadow); color: #fff;
    transition: transform 0.18s ease;
  }
  .reel-card:hover { transform: translateY(-4px) scale(1.01); }
  .reel-card--savanna { background: linear-gradient(160deg, var(--savanna), var(--terracotta)); }
  .reel-card--ocean { background: linear-gradient(160deg, var(--ocean), var(--ocean-d)); }
  .reel-card__cover { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .reel-card__shade { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(0,0,0,0.15), rgba(0,0,0,0.55)); }
  .reel-card__body { position: absolute; inset: auto 0 0 0; padding: 1rem; text-align: left; }
  .reel-card__count { font-size: 0.78rem; font-weight: 700; opacity: 0.9; }
  .reel-card__title { font-family: var(--font-body); font-weight: 900; font-size: 1.5rem; margin: 0.1rem 0 0.5rem; line-height: 1.1; }
  .reel-card__play { font-size: 0.8rem; font-weight: 700; background: rgba(255,255,255,0.22); padding: 0.25rem 0.6rem; border-radius: 999px; }

  /* 뷰어 */
  .viewer { position: fixed; inset: 0; z-index: 100; background: rgba(14,12,10,0.96); display: grid; place-items: center; padding: 0.5rem; }
  .viewer[hidden] { display: none; }
  /* 높이 기준 + 비율(JS가 영상 실제 비율로 덮어씀) → 잘림/여백 없이 딱 맞음 */
  .viewer__stage { position: relative; height: min(96svh, 880px); aspect-ratio: 9/16; max-width: 96vw; border-radius: 16px; overflow: hidden; background: #000; box-shadow: 0 20px 60px rgba(0,0,0,0.5); }
  .viewer__media, .viewer__media img, .viewer__media video { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .viewer__media video { object-fit: contain; background: #000; } /* 화면녹화 비율 안 짤리게 */
  .viewer__ph { display: grid; place-items: center; font-size: 4rem; }
  .viewer__ph--savanna { background: linear-gradient(160deg, var(--savanna), var(--terracotta)); }
  .viewer__ph--ocean { background: linear-gradient(160deg, var(--ocean), var(--ocean-d)); }

  /* 상단 프로그레스 바 (인스타식) */
  .viewer__bars { position: absolute; top: 0.6rem; left: 0.6rem; right: 0.6rem; display: flex; gap: 4px; z-index: 6; pointer-events: none; }
  .vbar { flex: 1; height: 3px; border-radius: 3px; background: rgba(255,255,255,0.35); overflow: hidden; }
  .vbar > i { display: block; height: 100%; width: 0%; background: #fff; }

  .viewer__cap { position: absolute; inset: auto 0 0 0; padding: 2.2rem 1.1rem 1.3rem; z-index: 5; pointer-events: none;
    background: linear-gradient(180deg, transparent, rgba(0,0,0,0.75)); color: #fff; }
  .viewer__cap .s { display: inline-block; background: #fff; color: var(--ink); font-weight: 800; font-size: 0.8rem; padding: 0.2rem 0.6rem; border-radius: 999px; transform: rotate(-3deg); margin-bottom: 0.5rem; }
  .viewer__cap .c { font-weight: 700; font-size: 1.05rem; line-height: 1.45; margin: 0 0 0.35rem; word-break: keep-all; }
  .viewer__cap .p { font-size: 0.78rem; opacity: 0.8; }

  /* 탭 영역 (왼쪽=이전, 오른쪽=다음, 꾹=일시정지) */
  .viewer__zone { position: absolute; top: 0; bottom: 0; z-index: 7; cursor: pointer; }
  .viewer__zone--l { left: 0; width: 32%; }
  .viewer__zone--r { right: 0; width: 68%; }

  .viewer__close { position: absolute; top: 1rem; right: 1rem; z-index: 10; background: rgba(255,255,255,0.18); color: #fff; border: none; cursor: pointer; width: 42px; height: 42px; border-radius: 50%; font-size: 1.2rem; }
  .viewer__close:hover { background: rgba(255,255,255,0.32); }

  /* 보이는 이전/다음 버튼 */
  .viewer__nav { position: absolute; top: 50%; transform: translateY(-50%); z-index: 9; width: 40px; height: 40px; border-radius: 50%; border: none; cursor: pointer;
    background: rgba(255,255,255,0.22); color: #fff; font-size: 1.5rem; line-height: 1; display: grid; place-items: center; }
  .viewer__nav:hover { background: rgba(255,255,255,0.4); }
  .viewer__nav--prev { left: 0.5rem; }
  .viewer__nav--next { right: 0.5rem; }

  /* 구간검토용 시간 표시 */
  .viewer__time { position: absolute; top: 1.2rem; left: 0.7rem; z-index: 10; background: rgba(0,0,0,0.55); color: #fff; font-size: 0.75rem; font-weight: 700; padding: 0.2rem 0.5rem; border-radius: 6px; font-variant-numeric: tabular-nums; }
</style>

<script>
  const reels = JSON.parse(document.getElementById('reel-data')?.textContent || '[]');
  const IMG_MS = 3500;
  const byId = (id) => document.getElementById(id);
  const viewer = byId('story-viewer');
  const media = byId('vmedia'), bars = byId('vbars'), cap = byId('vcap'), stage = byId('vstage'), vtime = byId('vtime');

  let ri = 0, si = 0, raf = 0, segStart = 0, paused = false, pauseT = 0, mode = 'img', vid = null, downAt = 0;

  const clamp = (n) => Math.max(0, Math.min(100, n));
  const fills = () => Array.from(bars.children).map((b) => b.firstElementChild);
  const reel = () => reels[ri];
  const seg = () => reel().segments[si];

  function buildBars(n) {
    bars.innerHTML = '';
    for (let i = 0; i < n; i++) { const t = document.createElement('div'); t.className = 'vbar'; t.appendChild(document.createElement('i')); bars.appendChild(t); }
  }
  function baselineBars() { fills().forEach((f, i) => { f.style.width = i < si ? '100%' : '0%'; }); }
  function setCur(pct) { const f = fills()[si]; if (f) f.style.width = clamp(pct) + '%'; }
  function capHtml() {
    const r = reel(), s = seg();
    cap.innerHTML = `${s.sticker ? `<span class="s">${s.sticker}</span><br/>` : ''}${s.caption ? `<p class="c">${s.caption}</p>` : ''}<span class="p">${r.title} · ${si + 1}/${r.segments.length}</span>`;
  }
  function isVideoSrc(src, type) { return type === 'video' || /\.(mp4|webm|mov)$/i.test(src || ''); }

  function openReel(i) {
    ri = i; si = 0; const r = reels[i];
    buildBars(r.segments.length);
    stage.style.aspectRatio = ''; // 기본 9:16
    if (r.video) {
      media.innerHTML = `<video id="vv" playsinline webkit-playsinline></video>`; vid = byId('vv'); vid.src = r.video;
      // 영상 실제 비율에 박스를 맞춰 잘림/여백 없이 (같은 폰 녹화 가정)
      vid.addEventListener('loadedmetadata', () => {
        if (vid.videoWidth && vid.videoHeight) stage.style.aspectRatio = `${vid.videoWidth} / ${vid.videoHeight}`;
      }, { once: true });
    } else vid = null;
    viewer.hidden = false; viewer.setAttribute('aria-hidden', 'false'); document.body.style.overflow = 'hidden';
    vtime.hidden = !r.video; // 영상 reel 일 때만 구간검토용 시간 표시
    paused = false;
    goSeg();
    cancelAnimationFrame(raf); loop();
  }

  // 세그먼트 진입 (탭/이전·다음 시). 영상릴은 seek, 그 외는 미디어 로드.
  function goSeg() {
    const r = reel(), s = seg();
    baselineBars(); capHtml();
    if (r.video && vid) {
      mode = 'vreel';
      const startT = s.t ?? 0;
      const seek = () => { try { vid.currentTime = startT; } catch (e) {} };
      if (vid.readyState >= 1) seek(); else vid.addEventListener('loadedmetadata', seek, { once: true });
      if (!paused) vid.play().catch(() => {});
    } else if (s.media) {
      if (isVideoSrc(s.media, s.type)) {
        mode = 'vclip'; media.innerHTML = `<video id="vv" playsinline autoplay></video>`; vid = byId('vv');
        vid.src = s.media; vid.onended = () => next(); if (!paused) vid.play().catch(() => {});
      } else { mode = 'img'; vid = null; media.innerHTML = `<img src="${s.media}" alt=""/>`; segStart = performance.now(); }
    } else {
      mode = 'img'; vid = null;
      media.innerHTML = `<div class="viewer__ph viewer__ph--${r.tone || 'savanna'}">${s.sticker || '📷'}</div>`;
      segStart = performance.now();
    }
  }

  function segEnd() {
    const segs = reel().segments;
    if (si + 1 < segs.length && segs[si + 1].t != null) return segs[si + 1].t;
    return vid && isFinite(vid.duration) ? vid.duration : (seg().t ?? 0) + 5;
  }

  function loop() {
    raf = requestAnimationFrame(loop);
    if (paused) return;
    if (mode === 'vreel' && vid) {
      const s0 = seg().t ?? 0, e = segEnd();
      setCur((vid.currentTime - s0) / Math.max(0.1, e - s0) * 100);
      vtime.textContent = `⏱ ${vid.currentTime.toFixed(1)}s · ${si + 1}/${reel().segments.length} (t=${s0})`;
      if (vid.currentTime >= e - 0.04 || vid.ended) {
        const f = fills()[si]; if (f) f.style.width = '100%';
        if (si + 1 < reel().segments.length) { si++; capHtml(); } else onReelEnd();
      }
    } else if (mode === 'vclip' && vid) {
      if (isFinite(vid.duration) && vid.duration > 0) setCur(vid.currentTime / vid.duration * 100);
    } else {
      const pct = (performance.now() - segStart) / IMG_MS * 100;
      setCur(pct); if (pct >= 100) next();
    }
  }

  function next() { const f = fills()[si]; if (f) f.style.width = '100%'; if (si + 1 < reel().segments.length) { si++; goSeg(); } else onReelEnd(); }
  function prev() { if (si > 0) { si--; goSeg(); } else if (ri > 0) { openReel(ri - 1); } }
  function onReelEnd() { if (ri + 1 < reels.length) openReel(ri + 1); else close(); }
  function close() { cancelAnimationFrame(raf); viewer.hidden = true; viewer.setAttribute('aria-hidden', 'true'); document.body.style.overflow = ''; media.innerHTML = ''; vid = null; stage.style.aspectRatio = ''; }

  function pause() { if (paused) return; paused = true; pauseT = performance.now(); if (vid) vid.pause(); }
  function resume() { if (!paused) return; paused = false; if (mode === 'img') segStart += performance.now() - pauseT; if (vid) vid.play().catch(() => {}); }

  // 탭/홀드 처리
  function bindZone(el, dir) {
    el.addEventListener('pointerdown', () => { downAt = performance.now(); pause(); });
    const up = () => { const held = performance.now() - downAt; resume(); if (held < 260) (dir < 0 ? prev() : next()); };
    el.addEventListener('pointerup', up);
    el.addEventListener('pointercancel', () => resume());
    el.addEventListener('pointerleave', () => { if (paused) resume(); });
  }
  bindZone(byId('vzl'), -1);
  bindZone(byId('vzr'), 1);

  // 보이는 버튼 (확실한 네비게이션)
  byId('vprev').addEventListener('click', (e) => { e.stopPropagation(); prev(); });
  byId('vnext').addEventListener('click', (e) => { e.stopPropagation(); next(); });

  document.querySelectorAll('.reel-card').forEach((el) => el.addEventListener('click', () => openReel(Number(el.getAttribute('data-reel')))));
  byId('vclose').addEventListener('click', close);
  viewer.addEventListener('click', (e) => { if (e.target === viewer) close(); });
  document.addEventListener('keydown', (e) => {
    if (viewer.hidden) return;
    if (e.key === 'Escape') close();
    else if (e.key === 'ArrowLeft') prev();
    else if (e.key === 'ArrowRight') next();
    else if (e.key === ' ') { e.preventDefault(); paused ? resume() : pause(); }
  });
</script>
